# ==============================================================================
# AWS EC2 배포용 환경 변수 설정 템플릿 (.env.example)
#
# 사용 방법:
# 1. 이 파일을 복사하여 '.env' 파일을 생성합니다.
# 2. 각 변수에 맞는 실제 값을 설정합니다.
# 3. ⚠️ .env 파일은 중요 정보가 포함되어 있으므로 절대로 Git에 커밋하지 마세요.
# ==============================================================================

# 1. 실행 프로필 설정 (tidb 또는 rds)
SPRING_PROFILES_ACTIVE=tidb

# Docker Hub 사용자명 (EC2에서 Docker Hub 이미지를 풀할 때 사용)
DOCKERHUB_USERNAME=[YOUR_DOCKERHUB_USERNAME]

# 2. JVM 메모리 설정 (1GB RAM 프리티어 EC2 환경 최적화 설정)
JAVA_OPTS=-Xms128m -Xmx256m

# 3. AWS RDS MySQL 접속 정보
RDS_URL=jdbc:mysql://[RDS_ENDPOINT_HERE]:3306/recipekr?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true
RDS_USERNAME=[RDS_MASTER_USERNAME]
RDS_PASSWORD=[RDS_MASTER_PASSWORD]

# 4. TiDB Cloud 접속 정보 (백업/대체용)
TIDB_URL=jdbc:mysql://gateway01.ap-northeast-1.prod.aws.tidbcloud.com:4000/recipekr?useSSL=true&serverTimezone=Asia/Seoul
TIDB_USERNAME=2tKL7PvWWp5JakF.root
TIDB_PASSWORD=inZWb4Ps6xN5siFn

# 5. 외부 API 키
GEMINI_API_KEY=AIzaSyDZMsxz57xvwrX2v5SDzSNEm_lW65fsIUk

# 6. AWS S3 설정 (무료 프리티어 범위)
# IAM Instance Role을 설정했다면 아래 Access Key 설정은 필요 없으며, 로컬 검증 시에만 활용합니다.
AWS_ACCESS_KEY_ID=[YOUR_AWS_ACCESS_KEY_ID]
AWS_SECRET_ACCESS_KEY=[YOUR_AWS_SECRET_ACCESS_KEY]
AWS_DEFAULT_REGION=ap-northeast-2
AWS_S3_BUCKET=[YOUR_S3_BUCKET_NAME]
